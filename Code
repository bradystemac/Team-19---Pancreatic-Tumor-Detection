mid_scans = []
ground_truth = []

for path in tumor_cases_img:
  volume = nib.load(path)
  mid = volume.shape[2] // 2
  mid_slice = volume.dataobj[:, :, mid]
  mid_scans.append(mid_slice)
  ground_truth.append(1)

for path in no_tumor_cases_img:
  volume = nib.load(path)
  mid = volume.shape[2] // 2
  mid_slice = volume.dataobj[:, :, mid]
  mid_scans.append(mid_slice)
  ground_truth.append(0)

print(len(mid_scans))
print(len(ground_truth))

