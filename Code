from sklearn.tree import DecisionTreeClassifier
from sklearn.model_selection import GridSearchCV
from sklearn.linear_model import LogisticRegression
from sklearn.neighbors import KNeighborsClassifier
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix
from sklearn.svm import SVC
from sklearn.naive_bayes import GaussianNB
import numpy as np


models = {
    'DecisionTree': DecisionTreeClassifier(),
    'LogisticRegression': LogisticRegression(),
    'KNN': KNeighborsClassifier(),
    'SVC': SVC(),
    'NaiveBayes': GaussianNB()
}

params = {
    'DecisionTree': {'max_depth': [None, 3, 5],
                     'min_samples_split': [5, 10]},
    'LogisticRegression':
        {'C': [0.1, 1, 10], 'penalty': [None, 'l2']},
    'KNN': {'n_neighbors': [3, 5, 7], 'weights': ['uniform', 'distance']},
    'SVC': {'C': [0.1, 1, 10], 'kernel': ['poly', 'rbf']},
    'NaiveBayes': {}
}

best_model = None
best_param = None
best_score = 0
best_name = None

for model in models:
    grid_search = GridSearchCV(models[model], params[model], cv=3, scoring='accuracy')
    grid_search.fit(X_train, y_train)

    if grid_search.best_score_ > best_score:
        best_score = grid_search.best_score_
        best_param = grid_search.best_params_
        best_model = grid_search.best_estimator_
        best_name = model

print('Best Model:', best_name)
print('Best Parameters:', best_param)
print('CV Accuracy:', best_score)


#7.

y_pred = best_model.predict(X_test)

acc = accuracy_score(y_test, y_pred)
prec = precision_score(y_test, y_pred, average='weighted')
rec = recall_score(y_test, y_pred, average='weighted')

print("TEST RESULTS -", best_name)
print("Accuracy:", acc)
print("Precision:", prec)
print("Recall:", rec)

#TESTS:

results = {}

for model_name in models:
    grid_search = GridSearchCV(models[model_name], params[model_name], cv=3, scoring='accuracy')
    grid_search.fit(X_train, y_train)

    estimator = grid_search.best_estimator_
    y_pred = estimator.predict(X_test)

    results[model_name] = {
        'best_params': grid_search.best_params_,
        'cv_accuracy': grid_search.best_score_,
        'test_accuracy': accuracy_score(y_test, y_pred),
        'precision': precision_score(y_test, y_pred, average='weighted'),
        'recall': recall_score(y_test, y_pred, average='weighted'),
        'f1': f1_score(y_test, y_pred, average='weighted'),
    }

    if grid_search.best_score_ > best_score:
        best_score = grid_search.best_score_
        best_param = grid_search.best_params_
        best_model = estimator
        best_name = model_name

# Print all results
for name, r in results.items():
    print(f"\n{'='*40}")
    print(f"Model: {name}")
    print(f"  Best Params:   {r['best_params']}")
    print(f"  CV Accuracy:   {r['cv_accuracy']:.4f}")
    print(f"  Test Accuracy: {r['test_accuracy']:.4f}")
    print(f"  Precision:     {r['precision']:.4f}")
    print(f"  Recall:        {r['recall']:.4f}")
    print(f"  F1 Score:      {r['f1']:.4f}")

print(f"\n{'='*40}")
print(f"BEST OVERALL MODEL: {best_name}")
