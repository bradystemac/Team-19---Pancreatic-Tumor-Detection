#resizes and flattens all mid scans into X

import cv2
import numpy as np

RESIZE = (128, 128)  # good balance for SVM

X = []
y = []

# Tumor cases
for img in mid_scans[:len(tumor_cases_img)]:
    img_resized = cv2.resize(img, RESIZE)
    X.append(img_resized.flatten())
    y.append(1)

# No tumor cases
for img in mid_scans[len(tumor_cases_img):]:
    img_resized = cv2.resize(img, RESIZE)
    X.append(img_resized.flatten())
    y.append(0)

X = np.array(X)
y = np.array(y)

print(X.shape)
print(y.shape)

#normalizes all 16,384 pixel values in 1D array

from sklearn.preprocessing import StandardScaler

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

#splits data 90% training and 10% testing

from sklearn.model_selection import train_test_split

X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y,
    test_size=0.1,
    random_state=42,
    stratify=y
)

#creates SVM with certain parameters and trains on training set

